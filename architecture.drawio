<mxfile host="app.diagrams.net">
  <diagram name="CaseTracker overlay architecture" id="casetracker-arch">
    <mxGraphModel dx="1422" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="CaseTracker — engagement overlay over the Microsoft 365 system of record" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="1100" height="28" as="geometry" />
        </mxCell>

        <mxCell id="bandEntra" value="Microsoft Entra ID — identity provider" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f0fa;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;fontSize=12;dashed=0" vertex="1" parent="1">
          <mxGeometry x="260" y="50" width="860" height="110" as="geometry" />
        </mxCell>
        <mxCell id="bandOverlay" value="CaseTracker overlay — system of engagement (this codebase)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef3fb;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=12;dashed=0" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="1120" height="210" as="geometry" />
        </mxCell>
        <mxCell id="bandM365" value="Microsoft 365 — system of record (governed; the heavy data stays here)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eef7ee;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=12;dashed=0" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1120" height="250" as="geometry" />
        </mxCell>

        <mxCell id="actor" value="Caseworker" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="95" y="80" width="50" height="90" as="geometry" />
        </mxCell>

        <mxCell id="E1" value="Federated SSO sign-in&#10;+ Entra group → department / role&#10;(no passwords stored here)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="300" y="90" width="780" height="55" as="geometry" />
        </mxCell>

        <mxCell id="O1" value="Worker dashboard&#10;(one pane — planned)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="O2" value="Django backend + the Index (&quot;our data&quot;)&#10;case state · document links + metadata · journal records · family graph&#10;&#10;metadata only — never file bodies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="360" y="265" width="440" height="100" as="geometry" />
        </mxCell>
        <mxCell id="O3" value="Authorization &amp; gates&#10;dept scope (see) · role (do) · shielding (open)&#10;handoff gate · immutable journal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="860" y="268" width="260" height="95" as="geometry" />
        </mxCell>

        <mxCell id="M1" value="Microsoft Graph&#10;(delegated — acts as the signed-in worker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="400" y="515" width="400" height="55" as="geometry" />
        </mxCell>
        <mxCell id="M2" value="SharePoint / OneDrive&#10;documents · email bodies · attachments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="150" y="620" width="400" height="70" as="geometry" />
        </mxCell>
        <mxCell id="M3" value="Outlook&#10;calendars (reference / sync target)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="650" y="620" width="400" height="70" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="1. SSO sign-in" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="actor" target="E1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="identity + group → role" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="E1" target="O3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="2. uses dashboard" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="actor" target="O1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="O1" target="O2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="delegated Graph calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="O2" target="M1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="documents · mail trail" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="M1" target="M2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="calendars" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;fontSize=11" edge="1" parent="1" source="M1" target="M3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="3. open file — the drive enforces the actual open" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;dashed=1;strokeColor=#b85450;fontColor=#b85450;fontSize=11" edge="1" parent="1" source="O1" target="M2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
